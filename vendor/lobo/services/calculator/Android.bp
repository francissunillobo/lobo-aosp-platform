// ─────────────────────────────────────────────────────────────────────────────
// AIDL interface
//
// Generates NDK and Java Binder stubs from ICalculatorService.aidl.
// NDK backend used by the C++ service and client.
// Java backend used by Kotlin/Java callers.
// ─────────────────────────────────────────────────────────────────────────────
aidl_interface {
    name: "lobo_calculator_aidl",
    vendor_available: true,
    unstable: true,
    srcs: ["aidl/com/lobo/platform/calculator/ICalculatorService.aidl"],
    local_include_dir: "aidl",
    backend: {
        cpp: { enabled: false },
        ndk: { enabled: true },
        // Java backend disabled: CalculatorJavaClient not yet buildable as a
        // vendor module (see comment below). Re-enable when moving to system_ext.
        java: { enabled: false },
        rust: { enabled: false },
    },
}

// ─────────────────────────────────────────────────────────────────────────────
// Calculator service daemon
//
// Installed to: /vendor/bin/calculatord
// ─────────────────────────────────────────────────────────────────────────────
cc_binary {
    name: "calculatord",
    vendor: true,
    srcs: [
        "cpp/core/src/CalculatorServiceImpl.cpp",
        "cpp/core/src/main.cpp",
    ],
    local_include_dirs: [
        "cpp/core/include",
    ],
    shared_libs: [
        "libbinder_ndk",
        "liblog",
    ],
    static_libs: [
        "lobo_calculator_aidl-ndk",
    ],
    cflags: ["-Wall", "-Wextra", "-Werror"],
}

// ─────────────────────────────────────────────────────────────────────────────
// C++ client library
//
// Used by other C++ services that want to call the calculator.
// ─────────────────────────────────────────────────────────────────────────────
cc_library_static {
    name: "liblobo_calculator_client",
    vendor: true,
    srcs: ["cpp/client/src/CalculatorClient.cpp"],
    local_include_dirs: [
        "cpp/client/include",
    ],
    export_include_dirs: [
        "cpp/client/include",
    ],
    shared_libs: [
        "libbinder_ndk",
        "liblog",
    ],
    static_libs: [
        "lobo_calculator_aidl-ndk",
    ],
    cflags: ["-Wall", "-Wextra", "-Werror"],
}

// ─────────────────────────────────────────────────────────────────────────────
// Kotlin/Java client library — NOT BUILT YET
//
// Android 16 sets PRODUCT_ENFORCE_PRODUCT_PARTITION_INTERFACE which blocks
// platform_apis: true on vendor Java modules. At the same time, the Kotlin
// source uses android.os.ServiceManager (@hide) which requires platform_apis.
// These two rules cannot both be satisfied for a vendor java_library.
//
// Resolution: Java/Kotlin app callers must be placed on the system partition
// (system_ext or priv-app), not in vendor. Revisit when building the first
// Android app that needs to call calculatord from Java/Kotlin.
//
// The source files in java/ are kept as reference and will be moved to the
// correct partition module when needed.
// ─────────────────────────────────────────────────────────────────────────────
// java_library {
//     name: "CalculatorJavaClient",
//     ...
// }

// ─────────────────────────────────────────────────────────────────────────────
// VTS test binary
//
// Build:  m VtsCalculatorServiceTest
// Run:    atest VtsCalculatorServiceTest
// ─────────────────────────────────────────────────────────────────────────────
cc_test {
    name: "VtsCalculatorServiceTest",
    vendor: true,
    srcs: ["tests/src/VtsCalculatorServiceTest.cpp"],
    shared_libs: [
        "libbinder_ndk",
        "liblog",
    ],
    static_libs: [
        "lobo_calculator_aidl-ndk",
    ],
    test_suites: ["vts"],
    cflags: ["-Wall", "-Wextra", "-Werror"],
}
