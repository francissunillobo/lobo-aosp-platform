aidl_interface {
    name: "lobo_nameservice_aidl",
    vendor: true,
    srcs: ["aidl/**/*.aidl"],
    stability: "vintf",
    backend: {
        cpp: { enabled: true },
        java: { enabled: true },
    },
}

cc_binary {
    name: "NameService",
    vendor: true,
    srcs: [
        "cpp/core/src/main.cpp",
        "cpp/core/src/NameServiceImpl.cpp",
        "cpp/client/src/NameServiceClient.cpp",
    ],
    local_include_dirs: [
        "cpp/core/include",
        "cpp/client/include",
    ],
    shared_libs: ["libbase", "libbinder", "liblog", "libutils"],
    init_rc: ["name_service.rc"],
}

android_library {
    name: "NameServiceJavaClient",
    vendor: true,
    srcs: ["java/src/main/java/**/*.kt"],
    sdk_version: "current",
}
