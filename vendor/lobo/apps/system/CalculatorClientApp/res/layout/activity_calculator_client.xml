<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scroll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:paddingStart="12dp"
    android:paddingTop="24dp"
    android:paddingEnd="12dp"
    android:paddingBottom="88dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/label_a"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <EditText
            android:id="@+id/input_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/calculator_edittext_bg"
            android:hint="@string/hint_number_a"
            android:imeOptions="actionNext"
            android:inputType="numberSigned"
            android:minHeight="44dp"
            android:maxLines="1"
            android:nextFocusForward="@id/input_b"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#AAFFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_b"
            android:textAppearance="?android:attr/textAppearanceSmall" />

        <EditText
            android:id="@+id/input_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/calculator_edittext_bg"
            android:hint="@string/hint_number_b"
            android:imeOptions="actionDone"
            android:inputType="numberSigned"
            android:minHeight="44dp"
            android:maxLines="1"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#AAFFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_add"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:textSize="20sp"
                android:text="@string/op_add" />

            <Button
                android:id="@+id/btn_subtract"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:textSize="20sp"
                android:text="@string/op_subtract" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_multiply"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:textSize="20sp"
                android:text="@string/op_multiply" />

            <Button
                android:id="@+id/btn_divide"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:textSize="20sp"
                android:text="@string/op_divide" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/label_result" />

        <TextView
            android:id="@+id/result_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/result_placeholder"
            android:textAppearance="?android:attr/textAppearanceLarge" />
    </LinearLayout>
</ScrollView>
