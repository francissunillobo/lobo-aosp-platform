# Custom domain for MySystemApp.
# app_domain() grants standard app permissions (Binder, data dirs, logd, etc.)
# Extend this file when avc: denied appears in logcat for this package.
type mysystemapp, domain;
app_domain(mysystemapp)

# Allow Binder IPC
binder_use(mysystemapp)
