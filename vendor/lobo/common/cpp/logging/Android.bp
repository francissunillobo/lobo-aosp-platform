cc_library_static {
    name: "liblobo_logging",
    vendor: true,
    srcs: ["src/Logging.cpp"],
    export_include_dirs: ["include"],
    shared_libs: ["liblog"],
    cflags: ["-Wall", "-Werror"],
}

cc_test {
    name: "liblobo_logging_test",
    vendor: true,
    srcs: ["tests/src/LoggingTest.cpp"],
    static_libs: ["liblobo_logging"],
}
